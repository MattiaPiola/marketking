# Copy this file to .env.local and fill in your Supabase project credentials.
# Do NOT commit .env.local to version control.

# Supabase project URL (from Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (from Supabase Dashboard → Settings → API)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public URL of the deployed app (shown to admin when sharing join codes)
VITE_APP_URL=https://mercatovivo.netlify.app
