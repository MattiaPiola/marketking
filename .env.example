# Copy this file to .env.local and fill in your Supabase project credentials.
# Do NOT commit .env.local to version control.

# Supabase project URL
# → Supabase Dashboard → select your project → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key
# → Supabase Dashboard → select your project → Settings → API → Project API keys → anon / public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public URL of the deployed app (shown to admin when sharing join codes)
# → Netlify Dashboard → Site overview → the URL shown under your site name
VITE_APP_URL=https://mercatovivo.netlify.app
